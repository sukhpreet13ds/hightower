# Cloudinary — image uploads (blog featured image, logo, inline editor images).
# Get these from https://cloudinary.com/console (free tier is fine).
# Copy this file to ".env" and fill in your values, then restart the app.
#
# If these are left blank, uploads fall back to local storage in ./data/uploads
# (fine for local development; for production set Cloudinary so images persist).

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder name inside your Cloudinary account (defaults to "hightower")
CLOUDINARY_FOLDER=hightower
